<%layout("/layouts/boilerplate") %>

    <body> 
        <h3>Show All Listings</h3>
        <!-- <form action="/listings/new" method="GET">
            <button>Create new Listing</button>
    </form> -->
    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1">
    <%for(let listing of allListings){%>
        <a href="/listings/<%=listing._id%>" class="listing-link">
            <div class="card col listing-card">
                <div class="card-img-overlay">See Detail</div>
            <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem;">
            <div class="card-body">
                <p class="card-text"><b><%=listing.title%></b>
                    <br>
                    <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>/night
                </p>
            </div>
        </div>
        </a>
    <%}%> 
    </div>   
    </body>